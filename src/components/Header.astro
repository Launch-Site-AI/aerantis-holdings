---
import { brand } from '../config/brand';
import { client } from '../data/client';

const nav = [
  { label: 'Home',     href: '/' },
  { label: 'About',    href: '/about' },
  { label: 'Services', href: '/services' },
  { label: 'Reviews',  href: '/reviews' },
  { label: 'Blog',     href: '/blog' },
  { label: 'Contact',  href: '/contact' },
];

const baseUrl = (import.meta as { env?: { BASE_URL?: string } }).env?.BASE_URL ?? '/';
const withBase = (path: string) => {
  const normalizedBase = baseUrl.endsWith('/') ? baseUrl : `${baseUrl}/`;
  return `${normalizedBase}${path.replace(/^\/+/, '')}`;
};
const stripBase = (path: string) => {
  const base = baseUrl;
  if (base !== '/' && path.startsWith(base)) {
    const stripped = path.slice(base.length);
    return stripped ? `/${stripped.replace(/^\//, '')}` : '/';
  }
  return path;
};

const currentPath = stripBase(Astro.url.pathname);
---

<header
  class="sticky top-0 z-50 w-full border-b border-border bg-background/95 backdrop-blur-sm"
  data-base-url={baseUrl}
  transition:persist
>
  <div class="mx-auto flex max-w-site items-center justify-between px-4 py-3 sm:px-6">
    <!-- Logo -->
    <a
      href={withBase('/')}
      class="font-heading text-xl font-bold uppercase tracking-wide text-primary transition-opacity hover:opacity-80"
    >
      {brand.name}
    </a>

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-1 lg:flex" aria-label="Primary navigation">
      {nav.map(({ label, href }) => {
        const isActive = currentPath === href || (href !== '/' && currentPath.startsWith(href));
        return (
          <a
            href={withBase(href)}
            aria-current={isActive ? 'page' : undefined}
            class:list={[
              'rounded-md px-3 py-2 text-sm font-medium transition-colors',
              isActive
                ? 'bg-primary/10 text-primary'
                : 'text-text-muted hover:text-text',
            ]}
          >
            {label}
          </a>
        );
      })}
    </nav>

    <!-- Desktop CTA + phone -->
    <div class="hidden items-center gap-4 lg:flex">
      {client.license && (
        <span class="rounded-full border border-border bg-surface px-3 py-1 text-xs font-medium text-text-muted">
          {client.license}
        </span>
      )}
      <a
        href={`tel:${client.phoneForTel}`}
        class="text-sm font-semibold text-text hover:text-primary transition-colors"
      >
        {client.phoneFormatted}
      </a>
      <a
        href={withBase('/contact')}
        class="inline-flex min-h-[44px] items-center rounded-md bg-accent px-5 py-2.5 text-sm font-bold text-accent-fg shadow-sm transition-opacity hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
      >
        Free Quote
      </a>
    </div>

    <!-- Mobile menu button -->
    <button
      id="menu-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="mobile-menu"
      class="inline-flex min-h-[44px] min-w-[44px] items-center justify-center rounded-md text-text-muted hover:bg-surface lg:hidden"
    >
      <span class="sr-only">Toggle menu</span>
      <svg id="menu-icon-open" class="size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="menu-icon-close" class="hidden size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Mobile drawer -->
  <div
    id="mobile-menu"
    class="hidden border-t border-border bg-background px-4 pb-6 pt-2 lg:hidden"
  >
    <nav class="flex flex-col gap-1" aria-label="Mobile navigation">
      {nav.map(({ label, href }) => {
        const isActive = currentPath === href || (href !== '/' && currentPath.startsWith(href));
        return (
          <a
            href={withBase(href)}
            class:list={[
              'rounded-md px-3 py-3 text-base font-medium transition-colors',
              isActive
                ? 'bg-primary/10 text-primary'
                : 'text-text-muted hover:text-text hover:bg-surface',
            ]}
          >
            {label}
          </a>
        );
      })}
    </nav>

    <div class="mt-4 flex flex-col gap-3 border-t border-border pt-4">
      <a
        href={`tel:${client.phoneForTel}`}
        class="flex items-center gap-2 px-3 py-2 text-base font-semibold text-text"
      >
        <svg class="size-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        {client.phoneFormatted}
      </a>
      <a
        href={withBase('/contact')}
        class="flex min-h-[44px] items-center justify-center rounded-md bg-accent px-5 py-3 text-base font-bold text-accent-fg shadow-sm transition-opacity hover:opacity-90"
      >
        Get a Free Quote
      </a>
      {client.license && (
        <p class="px-3 pt-1 text-xs text-text-muted">{client.license}</p>
      )}
    </div>
  </div>
</header>

<script>
  (() => {
    const headerEl = document.querySelector('header');
    const btnEl = document.getElementById('menu-toggle');
    const menuEl = document.getElementById('mobile-menu');
    const iconOpenEl = document.getElementById('menu-icon-open');
    const iconCloseEl = document.getElementById('menu-icon-close');

    if (!headerEl || !btnEl || !menuEl || !iconOpenEl || !iconCloseEl) return;

    const header = /** @type {HTMLElement} */ (headerEl);
    const btn = /** @type {HTMLButtonElement} */ (btnEl);
    const menu = /** @type {HTMLElement} */ (menuEl);
    const iconOpen = /** @type {HTMLElement} */ (iconOpenEl);
    const iconClose = /** @type {HTMLElement} */ (iconCloseEl);
    if (header.dataset.menuInit === 'true') return;
    header.dataset.menuInit = 'true';

    const activeClasses = ['bg-primary/10', 'text-primary'];
    const inactiveDesktop = ['text-text-muted', 'hover:text-text'];
    const inactiveMobile = ['text-text-muted', 'hover:text-text', 'hover:bg-surface'];
    const baseUrl = header.dataset.baseUrl || '/';

    const isDesktop = () => window.matchMedia('(min-width: 1024px)').matches;

    /** @param {string} rawPath */
    const normalizePath = (rawPath) => {
      if (!rawPath) return '/';
      let path = rawPath;

      if (/^[a-zA-Z]+:/.test(path)) {
        try {
          path = new URL(path, window.location.origin).pathname;
        } catch {
          return '';
        }
      }

      if (!path.startsWith('/')) return '';

      if (baseUrl !== '/' && path.startsWith(baseUrl)) {
        const stripped = path.slice(baseUrl.length);
        path = stripped ? `/${stripped.replace(/^\/+/, '')}` : '/';
      }

      const collapsed = path.replace(/\/+/g, '/');
      return collapsed.length > 1 ? collapsed.replace(/\/+$/, '') : collapsed;
    };

    /**
     * @param {string} href
     * @param {string} currentPath
     */
    const isPathActive = (href, currentPath) => {
      if (!href) return false;
      if (href === '/') return currentPath === '/';
      return currentPath === href || currentPath.startsWith(`${href}/`);
    };

    const setMenuOpen = (nextOpen: boolean) => {
      // Hard stop: hamburger/drawer behavior is mobile-only.
      if (isDesktop()) nextOpen = false;
      btn.setAttribute('aria-expanded', String(nextOpen));
      menu.classList.toggle('hidden', !nextOpen);
      iconOpen.classList.toggle('hidden', nextOpen);
      iconClose.classList.toggle('hidden', !nextOpen);
    };

    function syncActiveLinks(nextPath = window.location.pathname) {
      const path = normalizePath(nextPath);
      const desktopLinks = header.querySelectorAll('nav[aria-label="Primary navigation"] a');
      const mobileLinks = header.querySelectorAll('#mobile-menu nav a');

      desktopLinks.forEach((link) => {
        const href = normalizePath(link.getAttribute('href') || '');
        const isActive = isPathActive(href, path);
        link.classList.toggle(activeClasses[0], isActive);
        link.classList.toggle(activeClasses[1], isActive);
        link.classList.toggle(inactiveDesktop[0], !isActive);
        link.classList.toggle(inactiveDesktop[1], !isActive);
        if (isActive) link.setAttribute('aria-current', 'page');
        else link.removeAttribute('aria-current');
      });

      mobileLinks.forEach((link) => {
        const href = normalizePath(link.getAttribute('href') || '');
        const isActive = isPathActive(href, path);
        link.classList.toggle(activeClasses[0], isActive);
        link.classList.toggle(activeClasses[1], isActive);
        link.classList.toggle(inactiveMobile[0], !isActive);
        link.classList.toggle(inactiveMobile[1], !isActive);
        link.classList.toggle(inactiveMobile[2], !isActive);
        if (isActive) link.setAttribute('aria-current', 'page');
        else link.removeAttribute('aria-current');
      });
    }

    btn.addEventListener('click', () => {
      if (isDesktop()) return;
      const isOpen = btn.getAttribute('aria-expanded') === 'true';
      setMenuOpen(!isOpen);
    });

    menu.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;
      if (target.closest('a[href]')) setMenuOpen(false);
    });

    header.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;
      const navLink = target.closest('nav[aria-label="Primary navigation"] a, #mobile-menu nav a');
      if (!(navLink instanceof HTMLAnchorElement)) return;
      syncActiveLinks(navLink.getAttribute('href') || window.location.pathname);
    });

    document.addEventListener('astro:before-preparation', () => setMenuOpen(false));
    document.addEventListener('astro:after-swap', () => {
      setMenuOpen(false);
      syncActiveLinks();
    });
    document.addEventListener('astro:page-load', () => syncActiveLinks());

    // Ensure mobile drawer can't stay open if viewport changes to desktop.
    window.addEventListener('resize', () => setMenuOpen(false));

    setMenuOpen(false);
    syncActiveLinks();
  })();
</script>
