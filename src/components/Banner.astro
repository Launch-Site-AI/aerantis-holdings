---
interface Props {
  title: string;
}

const { title } = Astro.props;

const baseUrl = (import.meta as { env?: { BASE_URL?: string } }).env?.BASE_URL ?? '/';
const withBase = (path: string) => `${baseUrl}${path.replace(/^\//, '')}`;
const stripBase = (path: string) => {
  const base = baseUrl;
  if (base !== '/' && path.startsWith(base)) {
    const stripped = path.slice(base.length);
    return stripped ? `/${stripped.replace(/^\//, '')}` : '/';
  }
  return path;
};

const segments = stripBase(Astro.url.pathname)
  .split('/')
  .filter(Boolean)
  .map((seg, i, arr) => ({
    label: seg.replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase()),
    href: '/' + arr.slice(0, i + 1).join('/'),
    isLast: i === arr.length - 1,
  }));
---

<section class="bg-primary py-14 sm:py-16 lg:py-20">
  <div class="mx-auto max-w-site px-4 sm:px-6">
    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="mb-4">
      <ol class="flex flex-wrap items-center gap-1.5 text-sm text-primary-fg/60">
        <li>
          <a href={withBase('/')} class="transition-colors hover:text-primary-fg">Home</a>
        </li>
        {segments.map(({ label, href, isLast }) => (
          <li class="flex items-center gap-1.5">
            <svg class="size-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
            {isLast ? (
              <span aria-current="page" class="text-primary-fg">{label}</span>
            ) : (
              <a href={withBase(href)} class="transition-colors hover:text-primary-fg">{label}</a>
            )}
          </li>
        ))}
      </ol>
    </nav>

    <h1 class="font-heading text-h1 font-bold uppercase text-primary-fg">
      {title}
    </h1>
  </div>
</section>
